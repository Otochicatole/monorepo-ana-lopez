generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Locale {
  id                      String                   @id @default(cuid())
  code                    String                   @unique
  name                    String
  isDefault               Boolean                  @default(false)
  isActive                Boolean                  @default(true)
  sortOrder               Int                      @default(0)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  aboutContents           AboutContent?
  galleryTypeTranslations GalleryTypeTranslation[]
  homeContents            HomeContent?

  @@index([isActive, sortOrder])
}

model HomeContent {
  id           Int       @id @default(autoincrement())
  localeId     String    @unique
  about        String
  imageAboutId Int
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  imageAbout   MediaFile @relation("HomeImageAbout", fields: [imageAboutId], references: [id])
  locale       Locale    @relation(fields: [localeId], references: [id])

  @@index([localeId])
}

model AboutContent {
  id        Int        @id @default(autoincrement())
  localeId  String     @unique
  text1     String?
  image1Id  Int?
  text2     String?
  image2Id  Int?
  text3     String?
  image3Id  Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  image1    MediaFile? @relation("AboutImage1", fields: [image1Id], references: [id])
  image2    MediaFile? @relation("AboutImage2", fields: [image2Id], references: [id])
  image3    MediaFile? @relation("AboutImage3", fields: [image3Id], references: [id])
  locale    Locale     @relation(fields: [localeId], references: [id])

  @@index([localeId])
}

model GalleryType {
  id           Int                      @id @default(autoincrement())
  documentId   String                   @unique @default(cuid())
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  deletedAt    DateTime?
  galleries    GalleryItem[]
  translations GalleryTypeTranslation[]
}

model GalleryTypeTranslation {
  id            Int         @id @default(autoincrement())
  galleryTypeId Int
  localeId      String
  name          String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  galleryType   GalleryType @relation(fields: [galleryTypeId], references: [id], onDelete: Cascade)
  locale        Locale      @relation(fields: [localeId], references: [id])

  @@unique([galleryTypeId, localeId])
  @@index([localeId])
}

model GalleryItem {
  id            Int          @id @default(autoincrement())
  documentId    String       @unique @default(cuid())
  name          String?
  mediaId       Int
  galleryTypeId Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  galleryType   GalleryType? @relation(fields: [galleryTypeId], references: [id])
  media         MediaFile    @relation("GalleryMedia", fields: [mediaId], references: [id])

  @@index([createdAt])
  @@index([galleryTypeId])
}

model MediaFile {
  id               Int            @id @default(autoincrement())
  documentId       String         @unique @default(cuid())
  name             String
  alternativeText  String?
  caption          String?
  width            Int?
  height           Int?
  formats          Json?
  hash             String?
  ext              String?
  mime             String
  size             Decimal
  url              String
  previewUrl       String?
  provider         String         @default("local")
  providerMetadata Json?
  focalPoint       Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  aboutImage1      AboutContent[] @relation("AboutImage1")
  aboutImage2      AboutContent[] @relation("AboutImage2")
  aboutImage3      AboutContent[] @relation("AboutImage3")
  galleryMedia     GalleryItem[]  @relation("GalleryMedia")
  homeImageAbout   HomeContent[]  @relation("HomeImageAbout")

  @@index([mime])
}

model ContactMessage {
  id                Int                @id @default(autoincrement())
  name              String
  lastName          String
  phone             String
  message           String
  emailStatus       ContactEmailStatus @default(PENDING)
  providerMessageId String?
  error             String?
  createdAt         DateTime           @default(now())
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  username     String    @unique
  passwordHash String
  blocked      Boolean   @default(false)
  roleId       String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  role         Role      @relation(fields: [roleId], references: [id])
  sessions     Session[]
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  code        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       AdminUser[]
  permissions RolePermission[]
}

model Permission {
  id      String           @id @default(cuid())
  action  String
  subject String
  roles   RolePermission[]

  @@unique([action, subject])
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique
  csrfTokenHash    String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([resource, resourceId])
}

enum ContactEmailStatus {
  PENDING
  SENT
  FAILED
}

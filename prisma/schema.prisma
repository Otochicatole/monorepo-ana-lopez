generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  en
  es_AR
}

enum ContactEmailStatus {
  PENDING
  SENT
  FAILED
}

model HomeContent {
  id           Int           @id @default(autoincrement())
  locale       Locale
  about        String
  imageAboutId Int
  imageAbout   MediaFile     @relation("HomeImageAbout", fields: [imageAboutId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@unique([locale])
  @@index([locale])
}

model AboutContent {
  id          Int           @id @default(autoincrement())
  locale      Locale
  text1       String?
  image1Id    Int?
  image1      MediaFile?    @relation("AboutImage1", fields: [image1Id], references: [id])
  text2       String?
  image2Id    Int?
  image2      MediaFile?    @relation("AboutImage2", fields: [image2Id], references: [id])
  text3       String?
  image3Id    Int?
  image3      MediaFile?    @relation("AboutImage3", fields: [image3Id], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@unique([locale])
  @@index([locale])
}

model GalleryType {
  id          Int           @id @default(autoincrement())
  documentId  String        @unique @default(cuid())
  locale      Locale
  name        String
  galleries   GalleryItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@unique([locale, name])
  @@index([locale])
}

model GalleryItem {
  id            Int           @id @default(autoincrement())
  documentId    String        @unique @default(cuid())
  name          String?
  mediaId       Int
  media         MediaFile     @relation("GalleryMedia", fields: [mediaId], references: [id])
  galleryTypeId Int?
  galleryType   GalleryType?  @relation(fields: [galleryTypeId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  @@index([createdAt])
  @@index([galleryTypeId])
}

model MediaFile {
  id              Int       @id @default(autoincrement())
  documentId      String    @unique @default(cuid())
  name            String
  alternativeText String?
  caption         String?
  width           Int?
  height          Int?
  formats         Json?
  hash            String?
  ext             String?
  mime            String
  size            Decimal
  url             String
  previewUrl      String?
  provider        String    @default("local")
  providerMetadata Json?
  focalPoint      Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  homeImageAbout HomeContent[] @relation("HomeImageAbout")
  galleryMedia   GalleryItem[] @relation("GalleryMedia")
  aboutImage1    AboutContent[] @relation("AboutImage1")
  aboutImage2    AboutContent[] @relation("AboutImage2")
  aboutImage3    AboutContent[] @relation("AboutImage3")

  @@index([mime])
}

model ContactMessage {
  id                Int                @id @default(autoincrement())
  name              String
  lastName          String
  phone             String
  message           String
  emailStatus       ContactEmailStatus @default(PENDING)
  providerMessageId String?
  error             String?
  createdAt         DateTime           @default(now())
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  username     String    @unique
  passwordHash String
  blocked      Boolean   @default(false)
  roleId       String
  role         Role      @relation(fields: [roleId], references: [id])
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  code        String           @unique
  description String?
  users       AdminUser[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id      String           @id @default(cuid())
  action  String
  subject String
  roles   RolePermission[]

  @@unique([action, subject])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @unique
  csrfTokenHash    String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([resource, resourceId])
}
